{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sway.body/racketsport/scaffold_tool_index_schema.json",
  "title": "Racketsport scaffold tool index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "scripts_root",
    "tests_root",
    "schema_root",
    "scope",
    "execution",
    "summary",
    "tools"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "artifact_type": {
      "const": "racketsport_scaffold_tool_index"
    },
    "scripts_root": {
      "const": "scripts/racketsport"
    },
    "tests_root": {
      "const": "tests/racketsport"
    },
    "schema_root": {
      "const": "docs/racketsport"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "indexed_globs",
        "excluded_globs",
        "repo_wide_hygiene_report"
      ],
      "properties": {
        "indexed_globs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^scripts(/racketsport)?/\\*\\.(py|sh)$"
          },
          "minItems": 1
        },
        "excluded_globs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "repo_wide_hygiene_report": {
          "const": false
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cpu_only",
        "runs_scaffold_commands",
        "uses_gpu",
        "downloads",
        "mutates_repo",
        "claims_build_or_eval_status"
      ],
      "properties": {
        "cpu_only": {
          "const": true
        },
        "runs_scaffold_commands": {
          "const": false
        },
        "uses_gpu": {
          "const": false
        },
        "downloads": {
          "const": false
        },
        "mutates_repo": {
          "const": false
        },
        "claims_build_or_eval_status": {
          "const": false
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool_count",
        "with_related_tests",
        "missing_related_tests",
        "with_direct_cli_tests",
        "missing_direct_cli_tests",
        "with_matching_json_schema_files",
        "missing_matching_json_schema_files",
        "category_counts"
      ],
      "properties": {
        "tool_count": {
          "type": "integer",
          "minimum": 0
        },
        "with_related_tests": {
          "type": "integer",
          "minimum": 0
        },
        "missing_related_tests": {
          "type": "integer",
          "minimum": 0
        },
        "with_direct_cli_tests": {
          "type": "integer",
          "minimum": 0
        },
        "missing_direct_cli_tests": {
          "type": "integer",
          "minimum": 0
        },
        "with_matching_json_schema_files": {
          "type": "integer",
          "minimum": 0
        },
        "missing_matching_json_schema_files": {
          "type": "integer",
          "minimum": 0
        },
        "category_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command_path",
          "stem",
          "category",
          "workstream",
          "task_prefix",
          "related_test",
          "direct_cli_test",
          "matching_schema"
        ],
        "properties": {
          "command_path": {
            "type": "string",
            "pattern": "^scripts/(racketsport/)?[^/]+\\.(py|sh)$"
          },
          "stem": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "workstream": {
            "type": ["string", "null"],
            "minLength": 1
          },
          "task_prefix": {
            "type": ["string", "null"],
            "minLength": 1
          },
          "related_test": {
            "type": ["string", "null"],
            "pattern": "^tests/racketsport/test_.+\\.py$"
          },
          "direct_cli_test": {
            "type": ["string", "null"],
            "pattern": "^tests/racketsport/test_.+\\.py$"
          },
          "matching_schema": {
            "type": ["string", "null"],
            "pattern": "^docs/racketsport/.+_schema\\.json$"
          }
        }
      }
    }
  }
}
