{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/racketsport/ball_audio_dataset_schema.json",
  "title": "Ball Track and Pop Audio Dataset Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "dataset_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "split", "source_type", "class_label"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Relative path under the manifest directory. Absolute paths and parent traversal are rejected by the validator."
          },
          "split": {
            "enum": ["test", "train", "val"]
          },
          "source_type": {
            "enum": ["pop_audio", "roboflow_ball_xy", "tracknet_ball_xy"]
          },
          "source_name": {
            "type": "string",
            "minLength": 1
          },
          "class_label": {
            "enum": ["ball_occluded", "ball_visible", "negative", "pop"]
          },
          "label_format": {
            "enum": ["roboflow_xy", "tracknet_xy"]
          },
          "frame_rate": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "sample_rate": {
            "type": "integer",
            "exclusiveMinimum": 0
          },
          "audio_format": {
            "const": "wav"
          },
          "duration_ms": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "visibility": {
            "enum": [0, 1, 2]
          },
          "augmentations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "enum": [
                "amplitude",
                "background_subtraction",
                "color_jitter",
                "copy_paste",
                "fps_sim",
                "h264_artifact",
                "jpeg_artifact",
                "mixup",
                "motion_blur",
                "noise_snr",
                "occlusion",
                "pitch_shift",
                "rir",
                "specaugment",
                "time_shift",
                "time_stretch"
              ]
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "source_type": {
                  "const": "roboflow_ball_xy"
                }
              },
              "required": ["source_type"]
            },
            "then": {
              "required": ["label_format"],
              "properties": {
                "class_label": {
                  "enum": ["ball_occluded", "ball_visible"]
                },
                "label_format": {
                  "const": "roboflow_xy"
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "source_type": {
                  "const": "tracknet_ball_xy"
                }
              },
              "required": ["source_type"]
            },
            "then": {
              "required": ["label_format"],
              "properties": {
                "class_label": {
                  "enum": ["ball_occluded", "ball_visible"]
                },
                "label_format": {
                  "const": "tracknet_xy"
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "source_type": {
                  "const": "pop_audio"
                }
              },
              "required": ["source_type"]
            },
            "then": {
              "required": ["sample_rate"],
              "properties": {
                "class_label": {
                  "enum": ["negative", "pop"]
                },
                "sample_rate": {
                  "const": 44100
                },
                "audio_format": {
                  "const": "wav"
                }
              }
            }
          }
        ]
      }
    }
  }
}
