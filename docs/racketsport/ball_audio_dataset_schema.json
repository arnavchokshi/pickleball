{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/racketsport/ball_audio_dataset_schema.json",
  "title": "Ball Track and Pop Audio Dataset Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "dataset_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "split", "source_type"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Relative path under the manifest directory. Absolute paths and parent traversal are rejected by the validator."
          },
          "split": {
            "enum": ["train", "val", "test"]
          },
          "source_type": {
            "enum": ["ball_track", "pop_audio"]
          },
          "frame_rate": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "sample_rate": {
            "type": "integer",
            "exclusiveMinimum": 0
          },
          "notes": {
            "type": "string"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "source_type": {
                  "const": "pop_audio"
                },
                "sample_rate": {}
              },
              "required": ["sample_rate"]
            },
            "then": {
              "properties": {
                "sample_rate": {
                  "const": 44100
                }
              }
            }
          }
        ]
      }
    }
  }
}
