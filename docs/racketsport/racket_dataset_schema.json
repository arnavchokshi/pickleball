{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/racketsport/racket_dataset_schema.json",
  "title": "Racket Data Source Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "dataset_id", "sources"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "dataset_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source_type", "path", "split", "annotations"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
          },
          "source_type": {
            "enum": ["racketvision", "synthetic_blenderproc", "aruco_gt"]
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Relative path under the manifest directory. Absolute paths and parent traversal are rejected by the validator."
          },
          "split": {
            "enum": ["eval", "test", "train", "val"]
          },
          "annotations": {
            "type": "object",
            "additionalProperties": false,
            "required": ["keypoints", "corners"],
            "properties": {
              "keypoints": {
                "type": "object",
                "additionalProperties": false,
                "required": ["names", "dimensions"],
                "properties": {
                  "names": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    },
                    "allOf": [
                      {
                        "contains": {
                          "const": "top"
                        }
                      },
                      {
                        "contains": {
                          "const": "bottom"
                        }
                      },
                      {
                        "contains": {
                          "const": "handle"
                        }
                      }
                    ],
                    "description": "Must include top, bottom, and handle; enforced by the validator."
                  },
                  "dimensions": {
                    "enum": [2, 3]
                  }
                }
              },
              "corners": {
                "type": "object",
                "additionalProperties": false,
                "required": ["names", "dimensions"],
                "properties": {
                  "names": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    },
                    "prefixItems": [
                      {
                        "const": "top_left"
                      },
                      {
                        "const": "top_right"
                      },
                      {
                        "const": "bottom_right"
                      },
                      {
                        "const": "bottom_left"
                      }
                    ],
                    "minItems": 4,
                    "maxItems": 4
                  },
                  "dimensions": {
                    "enum": [2, 3]
                  }
                }
              },
              "pose_labels": {
                "type": "object",
                "additionalProperties": false,
                "required": ["format", "coordinate_frame"],
                "properties": {
                  "format": {
                    "enum": ["aruco_marker_pose", "matrix_4x4", "quaternion_translation", "rvec_tvec"]
                  },
                  "coordinate_frame": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "segmentation_masks": {
                "type": "object",
                "additionalProperties": false,
                "required": ["format", "path"],
                "properties": {
                  "format": {
                    "enum": ["coco_rle", "png", "polygon"]
                  },
                  "path": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Relative path under the manifest directory. Absolute paths and parent traversal are rejected by the validator."
                  }
                }
              }
            }
          },
          "camera": {
            "type": "object",
            "additionalProperties": true
          },
          "fps": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "frame_count": {
            "type": "integer",
            "exclusiveMinimum": 0
          },
          "license": {
            "type": "string",
            "minLength": 1
          },
          "marker": {
            "type": "object",
            "additionalProperties": true
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
