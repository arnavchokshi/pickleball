+def test_registered_owner_rebind_uses_appearance_and_court_not_static_role_or_speed() -> (
+    None
+):
+    slot = SelectionSlot(
+        1,
+        "near",
+        "left",
+        (1.0, 0.0),
+        (90,),
+        ("seed",),
+        1.0,
+    )
+    registered = _fragment(
+        "seed",
+        10,
+        90,
+        90,
+        (-1.5, -3.0),
+        (1.0, 0.0),
+    )
+    owner_reentry = _fragment(
+        "owner-reentry",
+        10,
+        100,
+        104,
+        (1.5, -3.0),
+        _vector_at_cosine_distance(0.10),
+    )
+    same_role_spectator = _fragment(
+        "same-role-spectator",
+        50,
+        200,
+        204,
+        (-6.0, -3.0),
+        _vector_at_cosine_distance(0.10),
+    )
+    owner_sources = {1: frozenset({10})}
+    owner_candidate = player_selection_module._binding_candidates(
+        owner_reentry,
+        slots=(slot,),
+        assignments={1: (registered,)},
+        stitch_vetoes=set(),
+        fps=30.0,
+        config=PlayerSelectionConfig(),
+        owner_source_ids_by_slot=owner_sources,
+    )[0]
+    spectator_candidate = player_selection_module._binding_candidates(
+        same_role_spectator,
+        slots=(slot,),
+        assignments={1: (registered,)},
+        stitch_vetoes=set(),
+        fps=30.0,
+        config=PlayerSelectionConfig(),
+        owner_source_ids_by_slot=owner_sources,
+    )[0]
+
+    assert owner_candidate.registered_owner_continuity
+    assert owner_candidate.open_set is OpenSetDecision.ACCEPT
+    assert not owner_candidate.role_consistent
+    assert not owner_candidate.temporal_motion_consistent
+    assert owner_candidate.feasible
+    assert not spectator_candidate.registered_owner_continuity
+    assert spectator_candidate.role_consistent
+    assert spectator_candidate.temporal_motion_consistent
+    assert spectator_candidate.fusion_score >= PlayerSelectionConfig().selection_score_min
+    assert not spectator_candidate.feasible
+
+
+def test_registered_owner_wins_same_frame_rebind_from_static_role_spectator() -> None:
+    records, positions, embeddings = _four_slot_records()
+    records.extend(
+        [
+            {
+                "frame": 40,
+                "source": 1,
+                "xy": positions[2],
+                "embedding": embeddings[1],
+            },
+            {
+                "frame": 40,
+                "source": 50,
+                "xy": positions[1],
+                "embedding": embeddings[1],
+            },
+        ]
+    )
+    raw_pool, embedding_payload = _raw_selection_inputs(records)
+    selected, report = select_players_payload(
+        _empty_tracks(),
+        raw_pool_payload=raw_pool,
+        embedding_payload=embedding_payload,
+        calibration=_identity_calibration(),
+        enabled=True,
+    )
+
+    near_left = next(
+        player
+        for player in selected["players"]
+        if (player["side"], player["role"]) == ("near", "left")
+    )
+    frame_40 = next(
+        frame for frame in near_left["frames"] if frame["frame_idx"] == 40
+    )
+    assert frame_40["world_xy"] == pytest.approx(list(positions[2]))
+    owner_decision = next(
+        decision
+        for decision in report["decisions"]
+        if str(decision.get("fragment_id", "")).startswith("pool-1-2-")
+    )
+    assert owner_decision["action"] == "rebind"
+    assert owner_decision["registered_owner_continuity"] is True
+    assert owner_decision["role_consistent"] is False
+    spectator_decision = next(
+        decision
+        for decision in report["decisions"]
+        if str(decision.get("fragment_id", "")).startswith("pool-50-")
+    )
+    assert spectator_decision["action"] == "leave_unbound"
+    assert any(
+        [frame["frame_idx"] for frame in observation["frames"]] == [40]
+        for observation in selected["unbound_observations"]
+    )
+
+
+def test_temporal_binding_uses_only_nearest_predecessor_and_successor() -> None:
+    stale_bad_anchor = _fragment(
+        "stale-bad-anchor",
+        1,
+        0,
+        0,
+        (100.0, -3.0),
+        (1.0, 0.0),
+    )
+    nearest_predecessor = _fragment(
+        "nearest-predecessor",
+        1,
+        90,
+        90,
+        (0.0, -3.0),
+        (1.0, 0.0),
+    )
+    candidate = _fragment(
+        "candidate",
+        1,
+        100,
+        100,
+        (0.0, -3.0),
+        (1.0, 0.0),
+    )
+    nearest_successor = _fragment(
+        "nearest-successor",
+        1,
+        110,
+        110,
+        (0.0, -3.0),
+        (1.0, 0.0),
+    )
+    stale_bad_successor = _fragment(
+        "stale-bad-successor",
+        1,
+        200,
+        200,
+        (100.0, -3.0),
+        (1.0, 0.0),
+    )
+
+    assert player_selection_module._fragment_inside_slot_motion_envelope(
+        candidate,
+        (
+            stale_bad_anchor,
+            nearest_predecessor,
+            nearest_successor,
+            stale_bad_successor,
+        ),
+        fps=30.0,
+        max_speed_m_s=7.0,
+    )
+
+
+def test_layer_c_reserves_enrolled_source_from_recovery_into_another_slot() -> None:
+    records, positions, embeddings = _four_slot_records(end_frame=30)
+    positions[1] = (-0.2, -3.0)
+    positions[2] = (0.2, -3.0)
+    for record in records:
+        source = int(record["source"])
+        if source in {1, 2}:
+            record["xy"] = positions[source]
+    records.extend(
+        [
+            {
+                "frame": 34,
+                "source": 1,
+                "xy": positions[1],
+                "embedding": embeddings[1],
+            },
+            {
+                "frame": 32,
+                "source": 2,
+                "xy": positions[2],
+                "embedding": embeddings[1],
+            },
+        ]
+    )
+    raw_pool, embedding_payload = _raw_selection_inputs(records)
+    selected, report = select_players_payload(
+        _empty_tracks(),
+        raw_pool_payload=raw_pool,
+        embedding_payload=embedding_payload,
+        calibration=_identity_calibration(),
+        enabled=True,
+    )
+
+    assert not any(
+        decision["action"] == "recover_real" and decision.get("frame_idx") == 32
+        for decision in report["decisions"]
+    )
+    assert any(
+        [frame["frame_idx"] for frame in observation["frames"]] == [32]
+        for observation in selected["unbound_observations"]
+    )
+
+
+def test_layer_c_prefers_enrolled_source_over_closer_generic_accept() -> None:
+    slot = SelectionSlot(1, "near", "left", (1.0, 0.0), (0,), ("seed",), 1.0)
+    last = _detection(0, 10, (-0.2, -3.0), (1.0, 0.0))
+    enrolled_source = _detection(
+        1,
+        10,
+        (-0.2, -3.0),
+        _vector_at_cosine_distance(0.30),
+    )
+    generic = _detection(
+        1,
+        50,
+        (-0.2, -3.0),
+        _vector_at_cosine_distance(0.10),
+    )
+
+    recovered = recover_identity_conditioned_pool(
+        slot,
+        last_detection=last,
+        pool=(generic, enrolled_source),
+        fps=30.0,
+        preferred_source_track_ids=(10,),
+    )
+
+    assert recovered == (enrolled_source,)
+
