+
+    def _empty_report(reason: str) -> dict[str, Any]:
+        return CourtProposalReport(
+            clip=clip,
+            video=str(video_path),
+            image_size=(0, 0),
+            frame_indices=[],
+            proposals=[
+                CourtProposal(
+                    proposal_id="proposal_empty_0001",
+                    source="detector_v2_multiframe",
+                    court_keypoints={},
+                    scores={"overall": 0.0},
+                    gate={
+                        "auto_usable": False,
