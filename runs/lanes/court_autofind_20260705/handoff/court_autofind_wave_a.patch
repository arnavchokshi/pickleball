+    x2, y2 = float(p2[0]), float(p2[1])
+    if abs(y2 - y1) < 1e-9:
+        return (x1 + x2) / 2.0
+    t = (y - y1) / (y2 - y1)
+    return x1 + t * (x2 - x1)
